from tkinter import *
def  fahrenheit_to_celsius() :
    a = float(ent_temperature.get())   # تحويل إلى float
    b = (a - 32) / 1.8
    c = round(b, 2)  
    lbl_result.config(text=f"{c} \N{DEGREE CELSIUS}")

window=Tk()
window.title("Temperature Converter")
window.geometry("200x50")
window.resizable(width=False, height=False)
frm_entry = Frame(window)
ent_temperature = Entry(frm_entry, width=10)
lbl_temp = Label(frm_entry, text="\N{DEGREE FAHRENHEIT}")
ent_temperature.grid(row=0, column=0, sticky="e")
lbl_temp.grid(row=0, column=1, sticky="w")
btn_convert = Button(window, text="\N{RIGHTWARDS BLACK ARROW}", command=fahrenheit_to_celsius)
lbl_result = Label(window, text="\N{DEGREE CELSIUS}")
frm_entry.grid(row=0, column=0, padx=10)
btn_convert.grid(row=0, column=1, pady=10)
lbl_result.grid(row=0, column=2, padx=10)

window.mainloop()
